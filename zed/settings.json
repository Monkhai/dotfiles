// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "ui_font_weight": 500.0,
    "buffer_font_weight": 500.0,
    "diff_view_style": "unified",
    "show_edit_predictions": false,
    "icon_theme": {
        "mode": "dark",
        "light": "Zed (Default)",
        "dark": "Zed (Default)",
    },
    "git_panel": {
        "show_count_badge": true,
        "file_icons": true,
        "tree_view": true,
        "default_width": 360.0,
        "status_style": "icon",
        "dock": "right",
    },
    "ui_font_family": "JetBrains Mono",
    "agent": {
        "notify_when_agent_waiting": "never",
        "tool_permissions": {
            "default": "allow",
            "tools": {
                "delete_path": {
                    "default": "allow",
                },
                "terminal": {
                    "default": "allow",
                },
                "edit_file": {
                    "default": "allow",
                    "always_allow": [
                        {
                            "pattern": "^packages/edsdk/",
                        },
                    ],
                },
            },
        },
        "default_model": {
            "effort": "high",
            "provider": "anthropic",
            "model": "claude-opus-4-6-latest",
            "enable_thinking": true,
        },
        "dock": "left",
        "favorite_models": [],
        "model_parameters": [],
    },
    "agent_servers": {},
    "session": {
        "trust_all_worktrees": true,
    },
    "vim_mode": true,
    "project_panel": {
        "dock": "right",
        "auto_fold_dirs": false,
    },
    "relative_line_numbers": "enabled",
    "gutter": {
        "line_numbers": true,
    },
    "buffer_font_fallbacks": ["monospace"],
    "buffer_font_family": "JetBrains Mono",
    "auto_indent_on_paste": true,
    "linked_edits": true,
    "use_on_type_format": true,
    "show_whitespaces": "none",
    "ensure_final_newline_on_save": false,
    "preferred_line_length": 120,
    "hard_tabs": false,
    "tab_size": 4,
    "base_keymap": "VSCode",
    "ui_font_size": 16,
    "buffer_font_size": 15,
    "lsp": {
        "typescript-language-server": {
            "initialization_options": {
                "diagnosticsIgnoredCodes": [80001],
            },
        },
    },
    "prettier": {
        "allowed": false,
    },
    "languages": {
        "JavaScript": {
            "formatter": [],
            "code_actions_on_format": {
                "source.fixAll.eslint": true,
            },
        },
        "JSX": {
            "formatter": [],
            "code_actions_on_format": {
                "source.fixAll.eslint": true,
            },
        },
        "TypeScript": {
            "formatter": [],
            "code_actions_on_format": {
                "source.fixAll.eslint": true,
            },
        },
        "TSX": {
            "formatter": [],
            "code_actions_on_format": {
                "source.fixAll.eslint": true,
            },
        },
        "Svelte": {
            "formatter": [],
            "code_actions_on_format": {
                "source.fixAll.eslint": true,
            },
        },
    },
    "theme": {
        "mode": "dark",
        "light": "Dayfox - opaque",
        "dark": "Duskfox - opaque",
    },
}
